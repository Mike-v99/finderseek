{
  "crons": [
    {
      "path": "/api/cron-activate-hunts",
      "schedule": "0 8 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/pirate.html",
      "destination": "/newquest.html",
      "permanent": true
    },
    {
      "source": "/pirate",
      "destination": "/newquest.html",
      "permanent": true
    },
    {
      "source": "/pricing.html",
      "destination": "/gold.html",
      "permanent": true
    },
    {
      "source": "/pricing",
      "destination": "/gold.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/hunt.html",
      "destination": "/quest.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
